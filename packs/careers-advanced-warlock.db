{"_id":"MFBngI2gsIKYLFva","name":"Spy","type":"Career","img":"icons/svg/item-bag.svg","data":{"description":"<p>In the back-streets of the capital, in the passages of the palace, or on some foreign shore. You know where to go and who to speak with to find out what you need. And if you need something for your masters, easily done.</p>\n<p>Required equipment: Nondescript clothing, heavy cloak, poisoned dagger, and a concealed tube for vital messages.</p>","activeSystem":"warlock","isActive":false,"currentLevel":0,"adventuringSkills":{"warlock":{"Appraise":{"maximumLevel":0,"isCareerSkill":false},"Athletics":{"maximumLevel":14,"isCareerSkill":true},"Bargain":{"maximumLevel":0,"isCareerSkill":false},"Blunt":{"maximumLevel":0,"isCareerSkill":false},"Bow":{"maximumLevel":0,"isCareerSkill":false},"Brawling":{"maximumLevel":0,"isCareerSkill":false},"Command":{"maximumLevel":0,"isCareerSkill":false},"Crossbow":{"maximumLevel":0,"isCareerSkill":false},"Diplomacy":{"maximumLevel":0,"isCareerSkill":false},"Disguise":{"maximumLevel":16,"isCareerSkill":true},"Dodge":{"maximumLevel":14,"isCareerSkill":true},"Endurance":{"maximumLevel":0,"isCareerSkill":false},"History":{"maximumLevel":0,"isCareerSkill":false},"Incantation":{"maximumLevel":0,"isCareerSkill":false},"Intimidate":{"maximumLevel":0,"isCareerSkill":false},"Language":{"maximumLevel":0,"isCareerSkill":false},"Large blade":{"maximumLevel":0,"isCareerSkill":false},"Lie":{"maximumLevel":0,"isCareerSkill":false},"Medicine":{"maximumLevel":0,"isCareerSkill":false},"Navigation":{"maximumLevel":0,"isCareerSkill":false},"Ostler":{"maximumLevel":0,"isCareerSkill":false},"Persuasion":{"maximumLevel":16,"isCareerSkill":true},"Pole arm":{"maximumLevel":0,"isCareerSkill":false},"Repair":{"maximumLevel":0,"isCareerSkill":false},"Sleight of hand":{"maximumLevel":16,"isCareerSkill":true},"Small blade":{"maximumLevel":14,"isCareerSkill":true},"Spot":{"maximumLevel":0,"isCareerSkill":false},"Stealth":{"maximumLevel":0,"isCareerSkill":false