{"_id":"TKuhPyuAVk216hyW","name":"Scholar","type":"Career","img":"icons/svg/item-bag.svg","data":{"description":"<p>The world lies in books, open to your mind. There's no need to go anywhere, or at least there wouldn't be if there weren't more books to be found. Curse this impractical world!</p>\n<p>Required equipment: A stack of books on all manner of subjects, a quill and your own work, half written.</p>","isActive":false,"currentLevel":0,"activeSystem":"warlock","adventuringSkills":{"Appraise":{"isCareerSkill":true,"maximumLevel":14},"Athletics":{"isCareerSkill":false,"maximumLevel":0},"Bargain":{"isCareerSkill":false,"maximumLevel":0},"Blunt":{"isCareerSkill":false,"maximumLevel":0},"Bow":{"isCareerSkill":false,"maximumLevel":0},"Brawling":{"isCareerSkill":true,"maximumLevel":14},"Command":{"isCareerSkill":false,"maximumLevel":0},"Crossbow":{"isCareerSkill":false,"maximumLevel":0},"Diplomacy":{"isCareerSkill":false,"maximumLevel":0},"Disguise":{"isCareerSkill":false,"maximumLevel":0},"Dodge":{"isCareerSkill":false,"maximumLevel":0},"Endurance":{"isCareerSkill":false,"maximumLevel":0},"History":{"isCareerSkill":true,"maximumLevel":16},"Incantation":{"isCareerSkill":false,"maximumLevel":0},"Intimidate":{"isCareerSkill":false,"maximumLevel":0},"Language":{"isCareerSkill":true,"maximumLevel":16},"Large blade":{"isCareerSkill":false,"maximumLevel":0},"Lie":{"isCareerSkill":false,"maximumLevel":0},"Medicine":{"isCareerSkill":true,"maximumLevel":16},"Navigation":{"isCareerSkill":false,"maximumLevel":0},"Ostler":{"isCareerSkill":false,"maximumLevel":0},"Persuasion":{"isCareerSkill":false,"maximumLevel":0},"Pole arm":{"isCareerSkill":false,"maximumLevel":0},"Repair":{"isCareerSkill":true,"maximumLevel":14},"Sleight of hand":{"isCareerSkill":false,"maximumLevel":0},"Small blade":{"isCareerSkill":false,"maximumLevel":0},"Spot":{"isCareerSkill":false,"maximumLevel":0},"Stealth":{"isCareerSkill":false,"maximumLevel":0},"Streetwise":{"isCareerSkill":false,"maximumLevel":0},"S