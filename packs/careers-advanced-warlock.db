{"_id":"lz6HAEbNuzAhbqr8","name":"Priest","type":"Career","img":"icons/svg/item-bag.svg","data":{"description":"<p>You progressed through the ranks of your order, and now you are a priest. Others follow your words, as you follow your god, and their power flows through you.</p>\n<p>Required equipment: At least five spells, a habit, a jewelled hand to receive kisses, and benedictions to bestow on your flock.</p>","isActive":false,"currentLevel":0,"activeSystem":"warlock","adventuringSkills":{"Appraise":{"isCareerSkill":false,"maximumLevel":0},"Athletics":{"isCareerSkill":false,"maximumLevel":0},"Bargain":{"isCareerSkill":false,"maximumLevel":0},"Blunt":{"isCareerSkill":false,"maximumLevel":0},"Bow":{"isCareerSkill":false,"maximumLevel":0},"Brawling":{"isCareerSkill":false,"maximumLevel":0},"Command":{"isCareerSkill":false,"maximumLevel":0},"Crossbow":{"isCareerSkill":false,"maximumLevel":0},"Diplomacy":{"isCareerSkill":true,"maximumLevel":14},"Disguise":{"isCareerSkill":false,"maximumLevel":0},"Dodge":{"isCareerSkill":false,"maximumLevel":0},"Endurance":{"isCareerSkill":false,"maximumLevel":0},"History":{"isCareerSkill":true,"maximumLevel":16},"Incantation":{"isCareerSkill":true,"maximumLevel":16},"Intimidate":{"isCareerSkill":false,"maximumLevel":0},"Language":{"isCareerSkill":true,"maximumLevel":16},"Large blade":{"isCareerSkill":false,"maximumLevel":0},"Lie":{"isCareerSkill":false,"maximumLevel":0},"Medicine":{"isCareerSkill":false,"maximumLevel":0},"Navigation":{"isCareerSkill":false,"maximumLevel":0},"Ostler":{"isCareerSkill":true,"maximumLevel":14},"Persuasion":{"isCareerSkill":false,"maximumLevel":0},"Pole arm":{"isCareerSkill":false,"maximumLevel":0},"Repair":{"isCareerSkill":false,"maximumLevel":0},"Sleight of hand":{"isCareerSkill":false,"maximumLevel":0},"Small blade":{"isCareerSkill":false,"maximumLevel":0},"Spot":{"isCareerSkill":false,"maximumLevel":0},"Stealth":{"isCareerSkill":false,"maximumLevel":0},"Streetwise":{"isCareerSkill":false,"maximumLevel":0