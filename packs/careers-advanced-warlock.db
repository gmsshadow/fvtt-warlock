{"_id":"o6fggmrWyyYOWee5","name":"Explorer","type":"Career","img":"icons/svg/item-bag.svg","data":{"description":"<p>The wild lands hold no fear for you. Travelling across the Kingdom and beyond, you have discovered things others would only dream of, and seen things that defy belief. No one knows the wild like you do.</p>\n<p>Required equipment: A finely crafted bow, an arming sword, navigation equipment and a tent and camping gear.</p>","isActive":false,"currentLevel":0,"activeSystem":"warlock","adventuringSkills":{"Appraise":{"isCareerSkill":false,"maximumLevel":0},"Athletics":{"isCareerSkill":true,"maximumLevel":14},"Bargain":{"isCareerSkill":false,"maximumLevel":0},"Blunt":{"isCareerSkill":false,"maximumLevel":0},"Bow":{"isCareerSkill":true,"maximumLevel":16},"Brawling":{"isCareerSkill":false,"maximumLevel":0},"Command":{"isCareerSkill":false,"maximumLevel":0},"Crossbow":{"isCareerSkill":false,"maximumLevel":0},"Diplomacy":{"isCareerSkill":false,"maximumLevel":0},"Disguise":{"isCareerSkill":false,"maximumLevel":0},"Dodge":{"isCareerSkill":false,"maximumLevel":0},"Endurance":{"isCareerSkill":false,"maximumLevel":0},"History":{"isCareerSkill":false,"maximumLevel":0},"Incantation":{"isCareerSkill":false,"maximumLevel":0},"Intimidate":{"isCareerSkill":false,"maximumLevel":0},"Language":{"isCareerSkill":false,"maximumLevel":0},"Large blade":{"isCareerSkill":false,"maximumLevel":0},"Lie":{"isCareerSkill":false,"maximumLevel":0},"Medicine":{"isCareerSkill":false,"maximumLevel":0},"Navigation":{"isCareerSkill":true,"maximumLevel":16},"Ostler":{"isCareerSkill":false,"maximumLevel":0},"Persuasion":{"isCareerSkill":false,"maximumLevel":0},"Pole arm":{"isCareerSkill":false,"maximumLevel":0},"Repair":{"isCareerSkill":false,"maximumLevel":0},"Sleight of hand":{"isCareerSkill":false,"maximumLevel":0},"Small blade":{"isCareerSkill":true,"maximumLevel":14},"Spot":{"isCareerSkill":true,"maximumLevel":16},"Stealth":{"isCareerSkill":false,"maximumLevel":0},"Streetwise":{"isCareerSk