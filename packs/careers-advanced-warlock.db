{"_id":"TKuhPyuAVk216hyW","name":"Scholar","type":"Career","img":"icons/svg/item-bag.svg","data":{"description":"<p>The world lies in books, open to your mind. There's no need to go anywhere, or at least there wouldn't be if there weren't more books to be found. Curse this impractical world!</p>\n<p>Required equipment: A stack of books on all manner of subjects, a quill and your own work, half written.</p>","activeSystem":"warlock","isActive":false,"currentLevel":0,"adventuringSkills":{"warlock":{"Appraise":{"maximumLevel":14,"isCareerSkill":true},"Athletics":{"maximumLevel":0,"isCareerSkill":false},"Bargain":{"maximumLevel":0,"isCareerSkill":false},"Blunt":{"maximumLevel":0,"isCareerSkill":false},"Bow":{"maximumLevel":0,"isCareerSkill":false},"Brawling":{"maximumLevel":14,"isCareerSkill":true},"Command":{"maximumLevel":0,"isCareerSkill":false},"Crossbow":{"maximumLevel":0,"isCareerSkill":false},"Diplomacy":{"maximumLevel":0,"isCareerSkill":false},"Disguise":{"maximumLevel":0,"isCareerSkill":false},"Dodge":{"maximumLevel":0,"isCareerSkill":false},"Endurance":{"maximumLevel":0,"isCareerSkill":false},"History":{"maximumLevel":16,"isCareerSkill":true},"Incantation":{"maximumLevel":0,"isCareerSkill":false},"Intimidate":{"maximumLevel":0,"isCareerSkill":false},"Language":{"maximumLevel":16,"isCareerSkill":true},"Large blade":{"maximumLevel":0,"isCareerSkill":false},"Lie":{"maximumLevel":0,"isCareerSkill":false},"Medicine":{"maximumLevel":16,"isCareerSkill":true},"Navigation":{"maximumLevel":0,"isCareerSkill":false},"Ostler":{"maximumLevel":0,"isCareerSkill":false},"Persuasion":{"maximumLevel":0,"isCareerSkill":false},"Pole arm":{"maximumLevel":0,"isCareerSkill":false},"Repair":{"maximumLevel":14,"isCareerSkill":true},"Sleight of hand":{"maximumLevel":0,"isCareerSkill":false},"Small blade":{"maximumLevel":0,"isCareerSkill":false},"Spot":{"maximumLevel":0,"isCareerSkill":false},"Stealth":{"maximumLevel":0,"isCareerSkill":false},"Streetwise":{"maximumLevel":0,"isCareerSkill