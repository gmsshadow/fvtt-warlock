{"_id":"JWsIF44JVHaNoF7j","name":"Freelance","type":"Career","img":"icons/svg/item-bag.svg","data":{"description":"<p>You are an armoured knight who pledges allegiance to whomever please you. As long as they pay enough to maintain your armour and your steed, you can afford to be picky. Maybe you fight for those of noble heart, maybe not. The choice is yours.</p>\n<p>Required equipment: A finely crafted sword, plate armour and shield (heavy armour), and a warhorse. A colourful tent and camping gear.</p>","activeSystem":"warlock","isActive":false,"currentLevel":0,"adventuringSkills":{"warlock":{"Appraise":{"maximumLevel":0,"isCareerSkill":false},"Athletics":{"maximumLevel":0,"isCareerSkill":false},"Bargain":{"maximumLevel":0,"isCareerSkill":false},"Blunt":{"maximumLevel":0,"isCareerSkill":false},"Bow":{"maximumLevel":0,"isCareerSkill":false},"Brawling":{"maximumLevel":0,"isCareerSkill":false},"Command":{"maximumLevel":0,"isCareerSkill":false},"Crossbow":{"maximumLevel":0,"isCareerSkill":false},"Diplomacy":{"maximumLevel":14,"isCareerSkill":true},"Disguise":{"maximumLevel":0,"isCareerSkill":false},"Dodge":{"maximumLevel":0,"isCareerSkill":false},"Endurance":{"maximumLevel":16,"isCareerSkill":true},"History":{"maximumLevel":0,"isCareerSkill":false},"Incantation":{"maximumLevel":0,"isCareerSkill":false},"Intimidate":{"maximumLevel":0,"isCareerSkill":false},"Language":{"maximumLevel":0,"isCareerSkill":false},"Large blade":{"maximumLevel":0,"isCareerSkill":false},"Lie":{"maximumLevel":0,"isCareerSkill":false},"Medicine":{"maximumLevel":14,"isCareerSkill":true},"Navigation":{"maximumLevel":0,"isCareerSkill":false},"Ostler":{"maximumLevel":16,"isCareerSkill":true},"Persuasion":{"maximumLevel":0,"isCareerSkill":false},"Pole arm":{"maximumLevel":16,"isCareerSkill":true},"Repair":{"maximumLevel":0,"isCareerSkill":false},"Sleight of hand":{"maximumLevel":0,"isCareerSkill":false},"Small blade":{"maximumLevel":0,"isCareerSkill":false},"Spot":{"maximumLevel":0,"isCareerSkill":false