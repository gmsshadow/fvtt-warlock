{"_id":"fLFkKiPKZ1pNCsmN","name":"Minstrel","type":"Career","img":"icons/svg/item-bag.svg","data":{"description":"<p>You have a voice like liquid gold, or can play an instrument like an angel. Or perhaps you just know the right stories. Anyway, you are moderately famous and respected, and have graced many a lord's table</p>\n<p>Required equipment: An instrument, finely crafted, a book of plays and poetry, the favour of a lord or lady.</p>","isActive":false,"currentLevel":0,"activeSystem":"warlock","adventuringSkills":{"Appraise":{"isCareerSkill":false,"maximumLevel":0},"Athletics":{"isCareerSkill":false,"maximumLevel":0},"Bargain":{"isCareerSkill":false,"maximumLevel":0},"Blunt":{"isCareerSkill":false,"maximumLevel":0},"Bow":{"isCareerSkill":false,"maximumLevel":0},"Brawling":{"isCareerSkill":false,"maximumLevel":0},"Command":{"isCareerSkill":false,"maximumLevel":0},"Crossbow":{"isCareerSkill":false,"maximumLevel":0},"Diplomacy":{"isCareerSkill":false,"maximumLevel":0},"Disguise":{"isCareerSkill":true,"maximumLevel":16},"Dodge":{"isCareerSkill":false,"maximumLevel":0},"Endurance":{"isCareerSkill":false,"maximumLevel":0},"History":{"isCareerSkill":true,"maximumLevel":14},"Incantation":{"isCareerSkill":false,"maximumLevel":0},"Intimidate":{"isCareerSkill":false,"maximumLevel":0},"Language":{"isCareerSkill":false,"maximumLevel":0},"Large blade":{"isCareerSkill":false,"maximumLevel":0},"Lie":{"isCareerSkill":true,"maximumLevel":14},"Medicine":{"isCareerSkill":false,"maximumLevel":0},"Navigation":{"isCareerSkill":false,"maximumLevel":0},"Ostler":{"isCareerSkill":false,"maximumLevel":0},"Persuasion":{"isCareerSkill":true,"maximumLevel":16},"Pole arm":{"isCareerSkill":false,"maximumLevel":0},"Repair":{"isCareerSkill":true,"maximumLevel":14},"Sleight of hand":{"isCareerSkill":true,"maximumLevel":16},"Small blade":{"isCareerSkill":false,"maximumLevel":0},"Spot":{"isCareerSkill":false,"maximumLevel":0},"Stealth":{"isCareerSkill":false,"maximumLevel":0},"Streetwise":{"isCareer