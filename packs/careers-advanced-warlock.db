{"_id":"lz6HAEbNuzAhbqr8","name":"Priest","type":"Career","img":"icons/svg/item-bag.svg","data":{"description":"<p>You progressed through the ranks of your order, and now you are a priest. Others follow your words, as you follow your god, and their power flows through you.</p>\n<p>Required equipment: At least five spells, a habit, a jewelled hand to receive kisses, and benedictions to bestow on your flock.</p>","activeSystem":"warlock","isActive":false,"currentLevel":0,"adventuringSkills":{"warlock":{"Appraise":{"maximumLevel":0,"isCareerSkill":false},"Athletics":{"maximumLevel":0,"isCareerSkill":false},"Bargain":{"maximumLevel":0,"isCareerSkill":false},"Blunt":{"maximumLevel":0,"isCareerSkill":false},"Bow":{"maximumLevel":0,"isCareerSkill":false},"Brawling":{"maximumLevel":0,"isCareerSkill":false},"Command":{"maximumLevel":0,"isCareerSkill":false},"Crossbow":{"maximumLevel":0,"isCareerSkill":false},"Diplomacy":{"maximumLevel":14,"isCareerSkill":true},"Disguise":{"maximumLevel":0,"isCareerSkill":false},"Dodge":{"maximumLevel":0,"isCareerSkill":false},"Endurance":{"maximumLevel":0,"isCareerSkill":false},"History":{"maximumLevel":16,"isCareerSkill":true},"Incantation":{"maximumLevel":16,"isCareerSkill":true},"Intimidate":{"maximumLevel":0,"isCareerSkill":false},"Language":{"maximumLevel":16,"isCareerSkill":true},"Large blade":{"maximumLevel":0,"isCareerSkill":false},"Lie":{"maximumLevel":0,"isCareerSkill":false},"Medicine":{"maximumLevel":0,"isCareerSkill":false},"Navigation":{"maximumLevel":0,"isCareerSkill":false},"Ostler":{"maximumLevel":14,"isCareerSkill":true},"Persuasion":{"maximumLevel":0,"isCareerSkill":false},"Pole arm":{"maximumLevel":0,"isCareerSkill":false},"Repair":{"maximumLevel":0,"isCareerSkill":false},"Sleight of hand":{"maximumLevel":0,"isCareerSkill":false},"Small blade":{"maximumLevel":0,"isCareerSkill":false},"Spot":{"maximumLevel":0,"isCareerSkill":false},"Stealth":{"maximumLevel":0,"isCareerSkill":false},"Streetwise":{"maximumLevel":0,"isCareerS