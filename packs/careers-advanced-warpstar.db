{"_id":"qFV3miE5O045GXnm","name":"Lawbringer","type":"Career","img":"icons/svg/item-bag.svg","data":{"description":"<p>You represent the law. Others look to you for guidance, and you show no mercy to law breakers. You are a hardened veteran, tough and uncompromising, and you are used to commanding others. They better listen, or else.</p>\n<p>Required equipment: A uniform, a warrant, a suitable vehicle and your trusty gun. What else do you need?</p>","isActive":false,"currentLevel":0,"adventuringSkills":{"Animal handler":{"isCareerSkill":false,"maximumLevel":0},"Appraise":{"isCareerSkill":true,"maximumLevel":14},"Astronav":{"isCareerSkill":false,"maximumLevel":0},"Athletics":{"isCareerSkill":false,"maximumLevel":0},"Bargain":{"isCareerSkill":false,"maximumLevel":0},"Blades":{"isCareerSkill":true,"maximumLevel":14},"Blunt":{"isCareerSkill":false,"maximumLevel":0},"Brawling":{"isCareerSkill":false,"maximumLevel":0},"Command":{"isCareerSkill":true,"maximumLevel":16},"Diplomacy":{"isCareerSkill":false,"maximumLevel":0},"Disguise":{"isCareerSkill":false,"maximumLevel":0},"Dodge":{"isCareerSkill":false,"maximumLevel":0},"Endurance":{"isCareerSkill":false,"maximumLevel":0},"History":{"isCareerSkill":false,"maximumLevel":0},"Intimidate":{"isCareerSkill":false,"maximumLevel":0},"Language":{"isCareerSkill":false,"maximumLevel":0},"Lie":{"isCareerSkill":false,"maximumLevel":0},"Medicine":{"isCareerSkill":false,"maximumLevel":0},"Navigation":{"isCareerSkill":false,"maximumLevel":0},"Persuasion":{"isCareerSkill":false,"maximumLevel":0},"Pilot":{"isCareerSkill":true,"maximumLevel":14},"Repair":{"isCareerSkill":false,"maximumLevel":0},"Ship gunner":{"isCareerSkill":false,"maximumLevel":0},"Small arms":{"isCareerSkill":true,"maximumLevel":16},"Sleight of hand":{"isCareerSkill":false,"maximumLevel":0},"Spot":{"isCareerSkill":false,"maximumLevel":0},"Stealth":{"isCareerSkill":false,"maximumLevel":0},"Streetwise":{"isCareerSkill":true,"maximumLevel":16},"Survival":{"isCareerSkill":fals