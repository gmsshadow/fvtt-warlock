{"_id":"x0ofW1U60gMLRcVX","name":"Duellist","type":"Career","img":"icons/svg/item-bag.svg","data":{"description":"<p>You fight the honourable way. When people want things settled in a legal manner, it's your sword arm they turn to. You've a quick wit and a modest air, but the blade is your friend, and others know it.</p>\n<p>Required equipment: A beautiful and ornate antique blade and a hidden pistol. Flashy clothes and a flashy smile.</p>","isActive":false,"currentLevel":0,"adventuringSkills":{"Animal handler":{"isCareerSkill":true,"maximumLevel":14},"Appraise":{"isCareerSkill":false,"maximumLevel":0},"Astronav":{"isCareerSkill":false,"maximumLevel":0},"Athletics":{"isCareerSkill":false,"maximumLevel":0},"Bargain":{"isCareerSkill":false,"maximumLevel":0},"Blades":{"isCareerSkill":true,"maximumLevel":16},"Blunt":{"isCareerSkill":false,"maximumLevel":0},"Brawling":{"isCareerSkill":true,"maximumLevel":14},"Command":{"isCareerSkill":true,"maximumLevel":14},"Diplomacy":{"isCareerSkill":true,"maximumLevel":16},"Disguise":{"isCareerSkill":false,"maximumLevel":0},"Dodge":{"isCareerSkill":false,"maximumLevel":0},"Endurance":{"isCareerSkill":false,"maximumLevel":0},"History":{"isCareerSkill":true,"maximumLevel":16},"Intimidate":{"isCareerSkill":false,"maximumLevel":0},"Language":{"isCareerSkill":false,"maximumLevel":0},"Lie":{"isCareerSkill":false,"maximumLevel":0},"Medicine":{"isCareerSkill":false,"maximumLevel":0},"Navigation":{"isCareerSkill":false,"maximumLevel":0},"Persuasion":{"isCareerSkill":false,"maximumLevel":0},"Pilot":{"isCareerSkill":false,"maximumLevel":0},"Repair":{"isCareerSkill":false,"maximumLevel":0},"Ship gunner":{"isCareerSkill":false,"maximumLevel":0},"Small arms":{"isCareerSkill":false,"maximumLevel":0},"Sleight of hand":{"isCareerSkill":false,"maximumLevel":0},"Spot":{"isCareerSkill":false,"maximumLevel":0},"Stealth":{"isCareerSkill":false,"maximumLevel":0},"Streetwise":{"isCareerSkill":false,"maximumLevel":0},"Survival":{"isCareerSkill":false,"maximu