{"_id":"HHGqRjLkTtYLZfYN","name":"Cult Leader","type":"Career","img":"icons/svg/item-bag.svg","data":{"description":"<p>The Chorus is awash with cults dedicated to the warp, to gods or to some local monster. You've either taken over an existing cult or created one yourself. Now others follow you, and you rest easy while they do the dirty work.</p>\n<p>Required equipment: Impressive clothes, a book of your creed and a suitable headquarters.</p>","isActive":false,"currentLevel":0,"adventuringSkills":{"Animal handler":{"isCareerSkill":false,"maximumLevel":0},"Appraise":{"isCareerSkill":false,"maximumLevel":0},"Astronav":{"isCareerSkill":false,"maximumLevel":0},"Athletics":{"isCareerSkill":false,"maximumLevel":0},"Bargain":{"isCareerSkill":false,"maximumLevel":0},"Blades":{"isCareerSkill":false,"maximumLevel":0},"Blunt":{"isCareerSkill":false,"maximumLevel":0},"Brawling":{"isCareerSkill":false,"maximumLevel":0},"Command":{"isCareerSkill":false,"maximumLevel":0},"Diplomacy":{"isCareerSkill":true,"maximumLevel":16},"Disguise":{"isCareerSkill":false,"maximumLevel":0},"Dodge":{"isCareerSkill":false,"maximumLevel":0},"Endurance":{"isCareerSkill":false,"maximumLevel":0},"History":{"isCareerSkill":true,"maximumLevel":16},"Intimidate":{"isCareerSkill":false,"maximumLevel":0},"Language":{"isCareerSkill":false,"maximumLevel":0},"Lie":{"isCareerSkill":true,"maximumLevel":14},"Medicine":{"isCareerSkill":false,"maximumLevel":0},"Navigation":{"isCareerSkill":false,"maximumLevel":0},"Persuasion":{"isCareerSkill":true,"maximumLevel":16},"Pilot":{"isCareerSkill":false,"maximumLevel":0},"Repair":{"isCareerSkill":false,"maximumLevel":0},"Ship gunner":{"isCareerSkill":false,"maximumLevel":0},"Small arms":{"isCareerSkill":false,"maximumLevel":0},"Sleight of hand":{"isCareerSkill":false,"maximumLevel":0},"Spot":{"isCareerSkill":false,"maximumLevel":0},"Stealth":{"isCareerSkill":false,"maximumLevel":0},"Streetwise":{"isCareerSkill":true,"maximumLevel":14},"Survival":{"isCareerSkill":false,"ma