{"_id":"0ZWdgkhrG2uh3MtH","name":"Wight","type":"Monster","img":"systems/warlock/assets/icons/monsters/raise-skeleton.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":33,"max":33}},"biography":{"notes":"Intelligent","description":"<p>Appearing much like emaciated near-skeletal humans, these undead have their own minds and desires. Wights often serve as the lieutenants of liches, where their armour-clad forms lead skeletal armies across the fields of war.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Otherworldly","weaponSkill":9,"adventuringSkills":6},"token":{"name":"Wight","img":"systems/warlock/assets/icons/monsters/shambling-zombie.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"1Xb7Eg6QMC48xxk2","name":"Giant","type":"Monster","img":"systems/warlock/assets/icons/monsters/giant.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":2},"stamina":{"value":39,"max":39}},"biography":{"notes":"Intelligent","description":"<p>To the far north live the giants, safely away from civilised folk. Giants are not evil, they are at best uncaring, and when they do venture from their wilderness homes the destruction they cause is usually a result of careless wandering. They can be conversed with, and have kingdoms of their own, but few of the 'little folk' have ever laid eyes on them.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Uncivilised","weaponSkill":8,"adventuringSkills":6},"token":{"name":"Giant","img":"systems/warlock/assets/icons/monsters/giant.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[{"_id":"bVjKipmHu7485PPL","name":"Club","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"3d6","type":{"value":"Crushing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}}},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"2DrYWx0Jt6E98GBF","name":"Treeman","type":"Monster","img":"systems/warlock/assets/icons/monsters/ent-mouth.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":2},"stamina":{"value":43,"max":43}},"biography":{"notes":"Intelligent, spell caster","description":"<p>The great treemen are found in the deepest woods, where they protect their woodland realm with a passion that quickly turns to anger should they be aroused. Allies of the elves, who also recognise the beauty of the forests, treemen are able to pull down buildings with their root-like grasp when driven into a rage.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Monster","weaponSkill":9,"adventuringSkills":4},"token":{"name":"Treeman","img":"systems/warlock/assets/icons/monsters/ent-mouth.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[{"_id":"Kb4teYoRWK465iiz","name":"Branch","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"2d6+3","type":{"value":"Crushing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}}},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}},{"_id":"pFRzHnftatDp5pWS","name":"Hide","type":"Armour","img":"icons/svg/item-bag.svg","data":{"description":"","isEquipped":true,"type":{"value":"","choices":{"":"","Light":"Light","Modest":"Modest","Heavy":"Heavy"}},"reductionRoll":"2d6"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"3Jw7XIwJ0hcz0DLu","name":"Wyvern","type":"Monster","img":"systems/warlock/assets/icons/monsters/wyvern.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":2},"stamina":{"value":32,"max":32}},"biography":{"notes":"Flying","description":"<p>A great winged serpent, wyverns hunt over some of the great plains and occasionally drift into the Kingdom. They are large enough to take cattle, and so can cause great destruction. Many a warrior has tested their mettle by hunting down and killing a wyvern before it hatches its eggs.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Monster","weaponSkill":7,"adventuringSkills":2},"token":{"name":"Wyvern","img":"systems/warlock/assets/icons/monsters/wyvern.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[{"_id":"1n8zTWZDxEcRUwWz","name":"Fang","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"2d6","type":{"value":"Piercing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Lar