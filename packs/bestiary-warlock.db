{"_id":"8IvsQrmNDq71giTJ","name":"Wraith","type":"Monster","img":"systems/warlock/assets/icons/monsters/spectre.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":2},"stamina":{"value":18,"max":18}},"biography":{"notes":"Ethereal","description":"<p>A ghastly undead, the wraith is a ghost that exists as an echo in the real world, anchored their by the anger and hatred. Wraiths seek life, if only to feel for some few moments the warmth of the real world.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Otherworldly","weaponSkill":8,"adventuringSkills":3},"token":{"name":"Wraith","img":"systems/warlock/assets/icons/monsters/spectre.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[{"_id":"UtEZ5b8QcBl1YQBV","name":"Ice touch","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"2d6+2","type":{"value":"Blast","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Smal