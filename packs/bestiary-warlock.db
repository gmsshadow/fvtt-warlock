{"_id":"ExEzWzCubDH4xD7q","name":"Griffin","type":"Monster","img":"systems/warlock/assets/icons/griffin-symbol.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":3},"stamina":{"value":41,"max":41}},"biography":{"notes":"Intelligent, flying","description":"<p>A noble beast with the body of a lion, the head and wings of an eagle, griffins are intelligent, sociable beings, and make great company. They have huge appetites however, and so are not often tolerated in civilised lands. It is however as common to see a sage sent to persuade the griffin to move on than it is to see warriors sent to destroy it, which is lucky considering the creature's might.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Monster","weaponSkill":8,"adventuringSkills":6},"token":{"name":"Griffin","img":"systems/warlock/assets/icons/griffin-symbol.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[{"_id":"T5TWzmOcbjFOpTvp","name":"Claw","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"2d6+1","type":{"value":"Slashing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"