{"_id":"RoI81YH8fC0JgPxK","name":"Skeleton","type":"Monster","img":"systems/warlock/assets/icons/monsters/raise-skeleton.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":8,"max":8}},"biography":{"notes":"Puppet, brittle","description":"<p>A mindless undead, typically under the command of a lich, skeletons are brittle and suffer great damage from blunt weapons, but will fight until destroyed if commanded to. Some wizards practice the creation of skeleton servants, but such activities are frowned upon, and necromancers are often driven from civilised lands and hunted.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Otherworldly","weaponSkill":4,"adventuringSkills":3},"token":{"name":"Skeleton","img":"systems/warlock/assets/icons/monsters/raise-skeleton.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"Sc2oS6hejTd1QG8T","name":"Hobgoblin","type":"Monster","img":"systems/warlock/assets/icons/monsters/orc-head.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":18,"max":18}},"biography":{"notes":"Intelligent","description":"<p>In truth goblins come in all shapes and sizes and the larger, more aggressive variety that rule over their smaller brethren are called hobgoblins. They are less hunched than their smaller kin, and can stand almost human height. Wicked and unpredictable, they are a violent and savage race, but not unintelligent - they make their own weapons and armour, and form bands under charismatic leaders that can threaten the stability of the realm.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Uncivilised","weaponSkill":7,"adventuringSkills":4},"token":{"name":"Hobgoblin","img":"systems/warlock/assets/icons/monsters/orc-head.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"WAm68bgrBG1uUeOw","name":"Halfling","type":"Monster","img":"systems/warlock/assets/icons/monsters/monk-face.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":8,"max":8}},"biography":{"notes":"Intelligent","description":"<p>A small folk, halflings are fairly commonly seen, and are quite integrated into human society. They are friendly and warm, quick to anger but quick to joy, and nicknamed the children due to their capricious but ultimately kind nature.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Civilised","weaponSkill":5,"adventuringSkills":5},"token":{"name":"Halfling","img":"systems/warlock/assets/icons/monsters/monk-face.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"c8HH0N1RZIEeNHXo","name":"Elf","type":"Monster","img":"systems/warlock/assets/icons/monsters/woman-elf-face.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":15,"max":15}},"biography":{"notes":"Intelligent","description":"<p>Elves are typically seen in the forests of the Kingdom, but they do come into the towns and cities, usually to barter goods with other folk. Tall and slight with dark hair and pointed ears, there is no mistaking an elf. They make good companions, but they often seem aloof, are prone to arrogance and can show contempt for 'lesser' races, which makes them outsiders in the polite society.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Civilised","weaponSkill":6,"adventuringSkills":5},"token":{"name":"Elf","img":"systems/warlock/assets/icons/monsters/woman-elf-face.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"fbEzvKUVcU7iGns5","name":"Dire Wolf","type":"Monster","img":"systems/warlock/assets/icons/monsters/wolf-head.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":12,"max":12}},"biography":{"notes":"Tracking","description":"<p>Great wolves almost the size of ponies, these creatures are aggressive predators. They are quite intelligent for animals, and work together as a pack to bring down large prey. The dire wolf has long been a partner of goblin-kind, who ride the beasts into war.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Monster","weaponSkill":5,"adventuringSkills":4},"token":{"name":"Dire Wolf","img":"systems/warlock/assets/icons/wolf-head.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[{"_id":"Uwm9tJt37AsboRIF","name":"Claw","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"1d6+1","type":{"value":"Slashing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}}},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}},{"_id":"ZrL8DiPiNqsYu0LM","name":"Fang","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"1d6+1","type":{"value":"Piercing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}}},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}},{"_id":"WrqJrFiA2WyvOuzM","name":"Hide","type":"Armour","img":"icons/svg/item-bag.svg","data":{"description":"","isEquipped":true,"type":{"value":"","choices":{"":"","Light":"Light","Modest":"Modest","Heavy":"Heavy"}},"reductionRoll":"1d3"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"l3avVrvEz2SoZHTM","name":"Troll","type":"Monster","img":"systems/warlock/assets/icons/monsters/troll.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":2},"stamina":{"value":28,"max":28}},"biography":{"notes":"Regenerating","description":"<p>Ugly and noisome beings, trolls are tall and gangly, with twisted limbs and scaled hides. They hunger for flesh of any kind, and can be hard to kill as they regenerate damage at a great rate. It is said the only way to really kill a troll is to hack it down and then burn it quickly, otherwise it will recover from even the most fatal seeming of blows.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Monster","weaponSkill":8,"adventuringSkills":6},"token":{"name":"Troll","img":"systems/warlock/assets/icons/monsters/troll.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[{"_id":"xZVzQ0aGAkNGNVGW","name":"Claw","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"1d6+4","type":{"value":"Slashing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}}},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}},{"_id":"SEkRTI2qWeHDH0b9","name":"Fang","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"1d6+4","type":{"value":"Piercing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}}},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}},{"_id":"TwETFVV4lKFFuBDE","name":"Hide","type":"Armour","img":"icons/svg/item-bag.svg","data":{"description":"","isEquipped":true,"type":{"value":"","choices":{"":"","Light":"Light","Modest":"Modest","Heavy":"Heavy"}},"reductionRoll":"1d6"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"uUweXaLIfk2J41U5","name":"Dwarf","type":"Monster","img":"systems/warlock/assets/icons/monsters/dwarf-face.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":15,"max":15}},"biography":{"notes":"Intelligent","description":"<p>The dwarves are a sturdy but diminutive people, quite similar to humans but slower and more thoughtful in nature. They can be stubborn, greedy and stoic, but make firm friends if treated with respect. Their great Kingdoms lie underground, where they war constantly with the goblins and hobgoblins, who covet their treasures as well as their fine Dwarven halls.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Civilised","weaponSkill":6,"adventuringSkills":5},"token":{"name":"Dwarf","img":"systems/warlock/assets/icons/monsters/dwarf-face.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"vshLpxVDUfsApzUN","name":"Lich","type":"Monster","img":"systems/warlock/assets/icons/monsters/crowned-skull.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":3},"stamina":{"value":45,"max":45}},"biography":{"notes":"Intelligent, spell caster","description":"<p>Truly foul beings, lichs are created when magic is abused. These undead spell casters are not of this world. Resembling skeletons, they are obsessed with magic and their own power, and often raise armies of the undead to do their bidding. Truly mad, lichs are one of the most dangerous foes that the Kingdom faces - rumours persist that the Traitor was aided by lichs.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Otherworldly","weaponSkill":9,"adventuringSkills":6},"token":{"name":"Lich","img":"systems/warlock/assets/icons/monsters/crowned-skull.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"0ZWdgkhrG2uh3MtH","name":"Wight","type":"Monster","img":"systems/warlock/assets/icons/monsters/raise-skeleton.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":33,"max":33}},"biography":{"notes":"Intelligent","description":"<p>Appearing much like emaciated near-skeletal humans, these undead have their own minds and desires. Wights often serve as the lieutenants of liches, where their armour-clad forms lead skeletal armies across the fields of war.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Otherworldly","weaponSkill":9,"adventuringSkills":6},"token":{"name":"Wight","img":"systems/warlock/assets/icons/monsters/shambling-zombie.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.0ZWdgkhrG2uh3MtH"}}}
{"_id":"1Xb7Eg6QMC48xxk2","name":"Giant","type":"Monster","img":"systems/warlock/assets/icons/monsters/giant.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":2},"stamina":{"value":39,"max":39}},"biography":{"notes":"Intelligent","description":"<p>To the far north live the giants, safely away from civilised folk. Giants are not evil, they are at best uncaring, and when they do venture from their wilderness homes the destruction they cause is usually a result of careless wandering. They can be conversed with, and have kingdoms of their own, but few of the 'little folk' have ever laid eyes on them.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Uncivilised","weaponSkill":8,"adventuringSkills":6},"token":{"name":"Giant","img":"systems/warlock/assets/icons/monsters/giant.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[{"_id":"bVjKipmHu7485PPL","name":"Club","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"3d6","type":{"value":"Crushing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}}},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.1Xb7Eg6QMC48xxk2"}}}
{"_id":"2DrYWx0Jt6E98GBF","name":"Treeman","type":"Monster","img":"systems/warlock/assets/icons/monsters/ent-mouth.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":2},"stamina":{"value":43,"max":43}},"biography":{"notes":"Intelligent, spell caster","description":"<p>The great treemen are found in the deepest woods, where they protect their woodland realm with a passion that quickly turns to anger should they be aroused. Allies of the elves, who also recognise the beauty of the forests, treemen are able to pull down buildings with their root-like grasp when driven into a rage.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Monster","weaponSkill":9,"adventuringSkills":4},"token":{"name":"Treeman","img":"systems/warlock/assets/icons/monsters/ent-mouth.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[{"_id":"Kb4teYoRWK465iiz","name":"Branch","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"2d6+3","type":{"value":"Crushing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}}},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}},{"_id":"pFRzHnftatDp5pWS","name":"Hide","type":"Armour","img":"icons/svg/item-bag.svg","data":{"description":"","isEquipped":true,"type":{"value":"","choices":{"":"","Light":"Light","Modest":"Modest","Heavy":"Heavy"}},"reductionRoll":"2d6"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.2DrYWx0Jt6E98GBF"}}}
{"_id":"3Jw7XIwJ0hcz0DLu","name":"Wyvern","type":"Monster","img":"systems/warlock/assets/icons/monsters/wyvern.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":2},"stamina":{"value":32,"max":32}},"biography":{"notes":"Flying","description":"<p>A great winged serpent, wyverns hunt over some of the great plains and occasionally drift into the Kingdom. They are large enough to take cattle, and so can cause great destruction. Many a warrior has tested their mettle by hunting down and killing a wyvern before it hatches its eggs.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Monster","weaponSkill":7,"adventuringSkills":2},"token":{"name":"Wyvern","img":"systems/warlock/assets/icons/monsters/wyvern.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[{"_id":"1n8zTWZDxEcRUwWz","name":"Fang","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"2d6","type":{"value":"Piercing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Lar