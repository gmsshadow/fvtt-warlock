{"_id":"8hTjuMvIDr7IRKjk","name":"Manticore","type":"Monster","img":"systems/warlock/assets/icons/monsters/griffin-symbol.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":3},"stamina":{"value":40,"max":40}},"biography":{"notes":"Intelligent, spell caster, flying, poisonous","description":"<p>Another magical creation, the manticore resembles a lion with the face of a man, huge bat wings and the tail of a scorpion. They are prodigious spell casters, and acquisition of magical items drives them. Some theorise that a sorcerer created them long ago to seek out items of power.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Monster","weaponSkill":9,"adventuringSkills":7},"token":{"name":"Manticore","img":"systems/warlock/assets/icons/griffin-symbol.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[{"_id":"43Jq3suL3dtsgeXg","name":"Claw","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"2d6","type":{"value":"Slashing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}}},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}},{"_id":"2ewEaiO5yQtK5J1V","name":"Fang","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"2d6","type":{"value":"Piercing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}}},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}},{"_id":"DVdRVhG5AjQpEUgr","name":"Hide","type":"Armour","img":"icons/svg/item-bag.svg","data":{"description":"","isEquipped":true,"type":{"value":"","choices":{"":"","Light":"Light","Modest":"Modest","Heavy":"Heavy"}},"reductionRoll":"1d3"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.8hTjuMvIDr7IRKjk"}}}
{"_id":"9nVYNO0fj8RL86ht","name":"Human","type":"Monster","img":"icons/svg/cowled.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":15,"max":15}},"biography":{"notes":"Intelligent","description":"<p>In the Kingdom there are many humans, whose desire to congregate makes them very populous. Many of these people have never strayed far from their homes, and apart from the odd elf, dwarf or halfling have never seen some of the other races that inhabit the Kingdom and the surrounding lands.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Civilised","weaponSkill":5,"adventuringSkills":5},"token":{"name":"Human","img":"systems/warlock/assets/icons/monsters/character.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.9nVYNO0fj8RL86ht"}}}
{"_id":"Cx9g6UFY947kk07F","name":"Ratman","type":"Monster","img":"systems/warlock/assets/icons/monsters/rat.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":10,"max":10}},"biography":{"notes":"Intelligent","description":"<p>In the cities of the Kingdom, many simply believe these filthy creatures don't exist. The wise know better. Ratmen infest the sewers and cellars of many towns, and form their own courts and kingdoms in a mockery of what lies above. They are intelligent and can talk, but their high pitched squeaky voices are hard to understand.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Uncivilised","weaponSkill":4,"adventuringSkills":3},"token":{"name":"Ratman","img":"systems/warlock/assets/icons/monsters/rat.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[],"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.Cx9g6UFY947kk07F"}}}
{"_id":"D25OqZsqi4Or5BfT","name":"Demon","type":"Monster","img":"systems/warlock/assets/icons/monsters/daemon-skull.svg","data":{"resources":{"actionsPerRound":{"value":1,"max":4},"stamina":{"value":42,"max":42}},"biography":{"notes":"Intelligent, spell caster","description":"<p>Demons come in all shapes and sizes, as this is a catch-all term of otherworldly beings draw to the material world. Here they can feed, and so most will do whatever they can to remain here. Wizards know that most spells are powered by demons, with whom their ancient forebears signed dread pacts in return for sacrifice. It seems most demons believe they got a rough end of that bargain in the end, and are constantly trying to wriggle out of the agreements they made, hence the strict wording of spells and the dire consequences of errors.</p>"},"gear":{"weapons":[],"armour":[],"equipment":[]},"type":"Otherworldly","weaponSkill":10,"adventuringSkills":6},"token":{"name":"Demon","img":"systems/warlock/assets/icons/daemon-skull.svg","displayName":0,"actorLink":false,"width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"alpha":1,"vision":false,"dimSight":0,"brightSight":0,"sightAngle":0,"light":{"alpha":0.5,"angle":0,"bright":0,"coloration":1,"dim":0,"gradual":true,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false},"darkness":{"min":0,"max":1}},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false},"items":[{"_id":"6moiip4o2Iiuj8F9","name":"Claw","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"2d6+3","type":{"value":"Slashing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}}},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}},{"_id":"MOFr2NEVFgQzRqVX","name":"Fang","type":"Weapon","img":"icons/svg/item-bag.svg","data":{"description":"","activeSystem":"warlock","isEquipped":true,"type":{"value":"","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"2d6+3","type":{"value":"Piercing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"—","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}}},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}},{"_id":"SPORQwArreX4Y7j4","name":"Hide","type":"Armour","img":"icons/svg/item-bag.svg","data":{"description":"","isEquipped":true,"type":{"value":"","choices":{"":"","Light":"Light","Modest":"Modest","Heavy":"Heavy"}},"reductionRoll":"1d6"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18