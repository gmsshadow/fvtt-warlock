{"_id":"0Xg1dOGqmdhfc8OY","name":"Miscast","img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","results":[{"_id":"uv0IGEPUrbS8WT2w","type":0,"text":"The caster's hands catch fire causing them [[/roll 1d6]] damage.","weight":1,"range":[1,1],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":1,"rangeH":1},{"_id":"lnxSf1736nWeZ31F","type":0,"text":"Two small horns grow from the casters head.","weight":1,"range":[2,2],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":2,"rangeH":2},{"_id":"S6fe5DDTA46HCYc0","type":0,"text":"One of the caster's eyes turns milky white.","weight":1,"range":[3,3],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":3,"rangeH":3},{"_id":"RTStQ75L8e9FXaaT","type":0,"text":"The spell discharges incorrectly, hitting the nearest creature for [[/roll 2d6]] damage.","weight":1,"range":[4,4],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":4,"rangeH":4},{"_id":"DrogbAH3OJWFKYfF","type":0,"text":"The caster's fingers elongate on one hand","weight":1,"range":[5,5],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":5,"rangeH":5},{"_id":"S9jjkytNfAdsfKpT","type":0,"text":"Blood runs from the caster's eyes for [[/roll 1d6]] days.","weight":1,"range":[6,6],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":6,"rangeH":6},{"_id":"eee3vepGfv6HYjVL","type":0,"text":"The spell backfires, blasting the caster across the room for [[/roll 2d6]] damage.","weight":1,"range":[7,7],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":7,"rangeH":7},{"_id":"aEcVsMkAlaAC3X95","type":0,"text":"An otherworldly being spies the caster, and appears in [[/roll 1d3]] rounds.","weight":1,"range":[8,8],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":8,"rangeH":8},{"_id":"7zMZKEutPoctX6OI","type":0,"text":"The caster loses the sense of taste, all food is like ash.","weight":1,"range":[9,9],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":9,"rangeH":9},{"_id":"dj2HHgVZSNRJIixn","type":0,"text":"The caster's skin is bleached white.","weight":1,"range":[10,10],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":10,"rangeH":10},{"_id":"SayKF1R0clZex1vH","type":0,"text":"All of the caster's hair falls out.","weight":1,"range":[11,11],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":11,"rangeH":11},{"_id":"lfIYnyRgLVdIRex3","type":0,"text":"The caster's skin becomes translucent for [[/roll 2d6]] days.","weight":1,"range":[12,12],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":12,"rangeH":12},{"_id":"xizJej3ZiKQwrjjy","type":0,"text":"The caster's arms are altered, growing small bone spurs.","weight":1,"range":[13,13],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":13,"rangeH":13},{"_id":"3o0EIXI440vxoIgN","type":0,"text":"The caster freezes like a statue for the next [[/roll 1d3]] days.","weight":1,"range":[14,14],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":14,"rangeH":14},{"_id":"aFh7BXLlT9qMX0PS","type":0,"text":"A miasma of magical mist fills a nearby space, causing [[/roll 1d6]] damage to all.","weight":1,"range":[15,15],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":15,"rangeH":15},{"_id":"pC1fW7kkn5Rn2gRD","type":0,"text":"The caster's eyes turn jet black for [[/roll 1d6]] weeks.","weight":1,"range":[16,16],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":16,"rangeH":16},{"_id":"Wp8QydRoboaL8jIL","type":0,"text":"The caster is possessed by an otherworldly being for [[/roll 1d6]] turns.","weight":1,"range":[17,17],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":17,"rangeH":17},{"_id":"2foQML5cumKdDO91","type":0,"text":"The caster loses the ability to cast spells for [[/roll 1d6]] days, every attempt miscasts.","weight":1,"range":[18,18],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":18,"rangeH":18},{"_id":"jOX689jkjr9jpNeW","type":0,"text":"The caster's face is frozen in a grimace of pain for [[/roll 1d6]] days.","weight":1,"range":[19,19],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":19,"rangeH":19},{"_id":"G0I6HwjyJsmp0yHI","type":0,"text":"The caster's arms become covered in small scales.","weight":1,"range":[20,20],"drawn":false,"flags":{},"img":"systems/warlock/assets/icons/items/spells/wind-hole.svg","rangeL":20,"rangeH":20}],"formula":"1d20","replacement":true,"displayRoll":true,"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"D9NqQLR8AwP8u2yU","name":"Critical - Blast","img":"icons/svg/skull.svg","results":[{"_id":"6TcBN31dEAlEUY60","type":0,"text":"Weapon too hot to touch! Drop it and draw something else, quick!","weight":1,"range":[2,2],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":2,"rangeH":2},{"_id":"CcVveufJohy4amh7","type":0,"text":"Clothing on fire! Spend [[/roll 1d6]] rounds doing nothing except putting it out.","weight":1,"range":[3,3],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":3,"rangeH":3},{"_id":"7IxHwyz9h4A3aw40","type":0,"text":"You gear catches fire! Either put it out for [[/roll 1d6]] rounds, or let all that you own burn!","weight":1,"range":[4,4],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":4,"rangeH":4},{"_id":"9gYavI3vcDCh6ASx","type":0,"text":"Breathe in the fumes, coughing and spluttering for [[/roll 1d6]] rounds, all tests at a penalty of 3.","weight":1,"range":[5,5],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":5,"rangeH":5},{"_id":"rMCH56e8tES9zWKV","type":0,"text":"Blinded by the blast, permanent penalty of 2 to tests involving sight.","weight":1,"range":[6,6],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":6,"rangeH":6},{"_id":"VZpGOckXMlaL2aRN","type":0,"text":"Knocked off your feet and flung against the wall. Stunned and prone for [[/roll 1d6]] rounds, all tests at a penalty of 3.","weight":1,"range":[7,7],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":7,"rangeH":7},{"_id":"wGXFY5UrQnUj3rp7","type":0,"text":"Hair singed off, scalp red and raw. No hats or helmets for [[/roll 1d6]] days, all tests at penalty of 3 during this time.","weight":1,"range":[8,8],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":8,"rangeH":8},{"_id":"UxmbDo2MaBum6FJg","type":0,"text":"Full in the face, the blast destroys your sense of smell. All tests involving smell at a penalty of 3, now your companions are more bearable.","weight":1,"range":[9,9],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":9,"rangeH":9},{"_id":"LLJzhSwOxLLfJnka","type":0,"text":"Skin and bone seared, dead","weight":1,"range":[10,10],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":10,"rangeH":10}],"formula":"2d6","replacement":true,"displayRoll":true,"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"IOVaE4HdCDLQrfSi","name":"Critical - Crushing","img":"icons/svg/skull.svg","results":[{"_id":"f6n2boTHVjiykY6i","type":0,"text":"A rap on the skull sends teeth chattering, dazed for [[/roll 1d6]] rounds.","weight":1,"range":[2,2],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":2,"rangeH":2},{"_id":"btPcqoOXODOgU4LF","type":0,"text":"Foot crushed, hops around in agony for [[/roll 1d6]] rounds.","weight":1,"range":[3,3],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":3,"rangeH":3},{"_id":"tgYouSyiHgOemgKt","type":0,"text":"Dead leg, all tests involving movement at a penalty of 3 for [[/roll 1d3]] days.","weight":1,"range":[4,4],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":4,"rangeH":4},{"_id":"0pmbVfArmhY6pNjH","type":0,"text":"A whack in the guts, winded and wheezing, can only defend at a penalty of 3 for [[/roll 1d6]] rounds.","weight":1,"range":[5,5],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":5,"rangeH":5},{"_id":"oAuc2aYwo2JtDtEL","type":0,"text":"Hand crushed, determine which one (dominant/non-dominant). Drop what you were carrying and can't use hand for [[/roll 1d6]] days.","weight":1,"range":[6,6],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":6,"rangeH":6},{"_id":"SD08nPnC8aFfDiR7","type":0,"text":"Thumped on the temples and seeing stars! Passes out for [[/roll 1d6]] rounds.","weight":1,"range":[7,7],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":7,"rangeH":7},{"_id":"vw3Yrdl1K2UQm2eK","type":0,"text":"Right in the kidney! Peeing blood, all tests at a penalty of 5 for the next [[/roll 1d6]] days. Better hope there is not too much internal bleeding!","weight":1,"range":[8,8],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":8,"rangeH":8},{"_id":"2w5njy8dOOXBvx0H","type":0,"text":"Smack on the chin. Jaw fractured, slurred and garbled speech for [[/roll 1d6]] days. Broken and unsymmetrical face now.","weight":1,"range":[9,9],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":9,"rangeH":9},{"_id":"WLnTY4Ke3lRU0QIz","type":0,"text":"Smashed on the skull and brained, dead.","weight":1,"range":[10,10],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":10,"rangeH":10}],"formula":"2d6","replacement":true,"displayRoll":true,"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"SBEqdW8X67bFyEqD","name":"Critical - Slashing","img":"icons/svg/skull.svg","results":[{"_id":"LMUZjXrajEEHVNtJ","type":0,"text":"Flat of the blade across the skull, dazed for [[/roll 1d6]] rounds, all actions at a penalty of 2. Double vision for [[/roll 1d6]] days.","weight":1,"range":[2,2],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":2,"rangeH":2},{"_id":"qNWBj8PDxMGRjCpp","type":0,"text":"Slashed on the hip, falls over and can only crawl in the dirt for [[/roll 1d6]] rounds, all tests at a penalty of 3.","weight":1,"range":[3,3],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":3,"rangeH":3},{"_id":"8JjFSOUY9L6hDRMj","type":0,"text":"Cut on thigh, can only hobble for [[/roll 1d3]] days, Endurance test not to end up with a limp.","weight":1,"range":[4,4],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":4,"rangeH":4},{"_id":"egVaYTA1KRZ3GL0o","type":0,"text":"That was my foot! Can only hobble for [[/roll 1d6]] days. Toes loose in the boot.","weight":1,"range":[5,5],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":5,"rangeH":5},{"_id":"YJg5mcRPXK3ZBLJS","type":0,"text":"Slash on the back, opening muscles, can't carry a pack for [[/roll 1d6]] days.","weight":1,"range":[6,6],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":6,"rangeH":6},{"_id":"p55D8FV3RW6ncdBQ","type":0,"text":"Whoops, [[/roll 1d3]] fingers sliced off, randomly determine hand, drop what you're carrying.","weight":1,"range":[7,7],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":7,"rangeH":7},{"_id":"GofDMLAkuwhNqk9y","type":0,"text":"An ear is slashed! Permanent penalty of 2 to tests involving hearing.","weight":1,"range":[8,8],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":8,"rangeH":8},{"_id":"3kDPET3IVfhzkzaJ","type":0,"text":"Hacked in the shoulder! Determine which arm, tests involving that arm are at a penalty of 5 for [[/roll 1d6]] days.","weight":1,"range":[9,9],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":9,"rangeH":9},{"_id":"flY97ihwkljpF3Et","type":0,"text":"Cut through an artery, dead.","weight":1,"range":[10,10],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":10,"rangeH":10}],"formula":"2d6","replacement":true,"displayRoll":true,"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
{"_id":"eje4zrueHDZr1Ohk","name":"Critical - Piercing","img":"icons/svg/skull.svg","results":[{"_id":"vlgXM6ee1c5TWFtr","type":0,"text":"A jab in the forearm, pass a sleight-of-hand test to keep hold of your weapon.","weight":1,"range":[2,2],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":2,"rangeH":2},{"_id":"nv1mcRppcB3iLozb","type":0,"text":"A skewered rump! Very painful, all tests at a penalty of 3 for the next [[/roll 1d6]] rounds.","weight":1,"range":[3,3],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":3,"rangeH":3},{"_id":"9cjAvD7aM49Bv5yy","type":0,"text":"A prod in the guts, forces dinner up and over everyone. Spend [[/roll 1d6]] rounds retching, all actions are at a penalty of 3.","weight":1,"range":[4,4],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":4,"rangeH":4},{"_id":"CkJM59jJuXkX8eAA","type":0,"text":"Poked in the neck, can do nothing but gasp for breath and defend at a penalty of 2 for [[/roll 1d6]] rounds.","weight":1,"range":[5,5],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":5,"rangeH":5},{"_id":"vfesYVe7iJdV2KBE","type":0,"text":"Run through the shoulder, arm immobilised for [[/roll 1d6]] days.","weight":1,"range":[6,6],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":6,"rangeH":6},{"_id":"BMbrp2uSZbr6PlWR","type":0,"text":"Poked in the mouth, teeth everywhere. Hard to talk through the blood, even uglier than before.","weight":1,"range":[7,7],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":7,"rangeH":7},{"_id":"PokB55P5fXs0SVya","type":0,"text":"My eye! Permanent penalty of 2 to tests involving sight, ugly to boot.","weight":1,"range":[8,8],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":8,"rangeH":8},{"_id":"Wca3MPchv7uTyDfO","type":0,"text":"Through my hand! Drops weapon in pain. Hand a useless claw for [[/roll 1d6]] days.","weight":1,"range":[9,9],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":9,"rangeH":9},{"_id":"nnMkHuewaqdIeQHu","type":0,"text":"Stabbed through the heart or brain, dead.","weight":1,"range":[10,10],"drawn":false,"flags":{},"img":"icons/svg/skull.svg","rangeL":10,"rangeH":10}],"formula":"2d6","replacement":true,"displayRoll":true,"folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{}}
