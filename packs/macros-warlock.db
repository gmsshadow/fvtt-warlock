{"_id":"2UiONsUFj42ueYeJ","name":"Critical - Crushing","type":"script","author":"HcHB4gb18gtp2Q2n","img":"icons/svg/skull.svg","scope":"global","command":"await Dialog.prompt({\n    title: \"Critical - Crushing\",\n    content: `\n        <form class=\\\"warlock\\\">\n            <div class=\"form-group\">\n                <label>\n                    Negative Stamina\n                </label>\n                <input\n                    class=\\\"field\\\"\n                    type=\\\"number\\\">\n                <p class=\\\"hint\\\">\n                    Enter the amount of negative stamina as a positive number.\n                </p>\n            </div>\n        </form>\n    `,\n    label: \"Roll\",\n    callback: (html) => {\n        const modifier = html.find(\"input\").val();\n        const roll = new Roll(`2d6 + ${modifier}`);\n        const table = game.tables.find((table) => {\n            return table.name === \"Critical - Crushing\";\n        });\n        table.draw({\n            roll: roll,\n        });\n    },\n});","folder":null,"sort":0,"permission":{"default":0,"HcHB4gb18gtp2Q2n":3},"flags":{"core":{"sourceId":"Macro.2UiONsUFj42ueYeJ"}}}
