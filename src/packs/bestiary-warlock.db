ck.bestiary-warlock.8IvsQrmNDq71giTJ"}},"system":{"resources":{"actionsPerRound":{"value":2,"max":2},"stamina":{"value":18,"max":18}},"biography":{"description":"<p>A ghastly undead, the wraith is a ghost that exists as an echo in the real world, anchored their by the anger and hatred. Wraiths seek life, if only to feel for some few moments the warmth of the real world.</p>"},"type":"Otherworldly","weaponSkill":8,"adventuringSkills":3,"gear":{"weapons":[],"armour":[],"equipment":[]}},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"prototypeToken":{"name":"Wraith","displayName":0,"actorLink":false,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"light":{"alpha":0.5,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false,"type":null},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false,"texture":{"src":"systems/warlock/assets/icons/monsters/spectre.svg","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"color":null,"attenuation":0.1,"saturation":0,"contrast":0,"visionMode":"basic"},"detectionModes":[]},"_stats":{"systemId":"warlock","systemVersion":"2.0.0","coreVersion":"10.284","createdTime":1662145221514,"modifiedTime":1662411890759,"lastModifiedBy":"6R9Y3cM97XtOXeBn"}}
