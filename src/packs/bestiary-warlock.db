{"_id":"1Xb7Eg6QMC48xxk2","name":"Giant","type":"Monster","img":"systems/warlock/assets/icons/monsters/giant.svg","items":[{"_id":"bVjKipmHu7485PPL","name":"Club","type":"Weapon","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":"","isEquipped":true,"type":{"value":"—","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"3d6","type":{"value":"Crushing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"Weapon Skill","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}},"activeSystem":"warlock"},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"vlL8FgXPYauYZHyv","name":"Intelligent","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":700000,"flags":{"core":{"sourceId":"Item.viEhV1k2WBxXnAHV"}},"system":{"description":"<p>This being is intelligent, can speak (but perhaps not in a tongue the characters know) and use tools and weapons. It is also able to create strategies and plans.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.1Xb7Eg6QMC48xxk2"}},"system":{"resources":{"actionsPerRound":{"value":2,"max":2},"stamina":{"value":39,"max":39}},"biography":{"description":"<p>To the far north live the giants, safely away from civilised folk. Giants are not evil, they are at best uncaring, and when they do venture from their wilderness homes the destruction they cause is usually a result of careless wandering. They can be conversed with, and have kingdoms of their own, but few of the 'little folk' have ever laid eyes on them.</p>"},"type":"Uncivilised","weaponSkill":8,"adventuringSkills":6,"gear":{"weapons":[],"armour":[],"equipment":[]}},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"prototypeToken":{"name":"Giant","displayName":0,"actorLink":false,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"light":{"alpha":0.5,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false,"type":null},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false,"texture":{"src":"systems/warlock/assets/icons/monsters/giant.svg","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"color":null,"attenuation":0.1,"saturation":0,"contrast":0,"visionMode":"basic"},"detectionModes":[]},"_stats":{"systemId":"warlock","systemVersion":"2.0.0","coreVersion":"10.284","createdTime":1662145221502,"modifiedTime":1662412744001,"lastModifiedBy":"6R9Y3cM97XtOXeBn"}}
