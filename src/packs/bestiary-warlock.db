rey. The dire wolf has long been a partner of goblin-kind, who ride the beasts into war.</p>"},"type":"Monster","weaponSkill":5,"adventuringSkills":4,"gear":{"weapons":[],"armour":[],"equipment":[]}},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"prototypeToken":{"name":"Dire Wolf","displayName":0,"actorLink":false,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"light":{"alpha":0.5,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false,"type":null},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false,"texture":{"src":"systems/warlock/assets/icons/wolf-head.svg","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"color":null,"attenuation":0.1,"saturation":0,"contrast":0,"visionMode":"basic"},"detectionModes":[]},"_stats":{"systemId":"warlock","systemVersion":"2.0.0","coreVersion":"10.284","createdTime":1662145221674,"modifiedTime":1662411890778,"lastModifiedBy":"6R9Y3cM97XtOXeBn"}}
{"_id":"l3avVrvEz2SoZHTM","name":"Troll","type":"Monster","img":"systems/warlock/assets/icons/monsters/troll.svg","items":[{"_id":"xZVzQ0aGAkNGNVGW","name":"Claw","type":"Weapon","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":"","isEquipped":true,"type":{"value":"—","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"1d6+4","type":{"value":"Slashing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"Weapon Skill","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}},"activeSystem":"warlock"},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"SEkRTI2qWeHDH0b9","name":"Fang","type":"Weapon","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":"","isEquipped":true,"type":{"value":"—","choices":{"warlock":{"":"","Casual":"Casual","Martial":"Martial"},"warpstar":{"":"","Small":"Small","Medium":"Medium","Heavy":"Heavy"}}},"damage":{"roll":"1d6+4","type":{"value":"Piercing","choices":{"warlock":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Blast":"Blast"},"warpstar":{"":"","Crushing":"Crushing","Piercing":"Piercing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"Weapon Skill","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}},"activeSystem":"warlock"},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"TwETFVV4lKFFuBDE","name":"Hide","type":"Armour","img":"icons/svg/item-bag.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":"","isEquipped":true,"type":{"value":"","choices":{"":"","Light":"Light","Modest":"Modest","Heavy":"Heavy"}},"reductionRoll":"1d6"},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"ZaoKxAuC20pwmwal","name":"Regenerating","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":0,"flags":{"core":{"sourceId":"Item.9zIPNt2rdySokleu"}},"system":{"description":"<p>The being is able to recover damage. Every round the being regains [[/roll 1d6]] stamina, up to a maximum of its starting value.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.l3avVrvEz2SoZHTM"}},"system":{"resources":{"actionsPerRound":{"value":2,"max":2},"stamina":{"value":28,"max":28}},"biography":{"description":"<p>Ugly and noisome beings, trolls are tall and gangly, with twisted limbs and scaled hides. They hunger for flesh of any kind, and can be hard to kill as they regenerate damage at a great rate. It is said the only way to really kill a troll is to hack it down and then burn it quickly, otherwise it will recover from even the most fatal seeming of blows.</p>"},"type":"Monster","weaponSkill":8,"adventuringSkills":6,"gear":{"weapons":[],"armour":[],"equipment":[]}},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"prototypeToken":{"name":"Troll","displayName":0,"actorLink":false,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"light":{"alpha":0.5,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false,"type":null},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false,"texture":{"src":"systems/warlock/assets/icons/monsters/troll.svg","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"color":null,"attenuation":0.1,"saturation":0,"contrast":0,"visionMode":"basic"},"detectionModes":[]},"_stats":{"systemId":"warlock","systemVersion":"2.0.0","coreVersion":"10.284","createdTime":1662145221676,"modifiedTime":1662411890780,"lastModifiedBy":"6R9Y3cM97XtOXeBn"}}
{"_id":"uUweXaLIfk2J41U5","name":"Dwarf","type":"Monster","img":"systems/warlock/assets/icons/monsters/dwarf-face.svg","items":[{"_id":"OkTyCgrAf8U6o77o","name":"Intelligent","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":700000,"flags":{"core":{"sourceId":"Item.viEhV1k2WBxXnAHV"}},"system":{"description":"<p>This being is intelligent, can speak (but perhaps not in a tongue the characters know) and use tools and weapons. It is also able to create strategies and plans.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.uUweXaLIfk2J41U5"}},"system":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":15,"max":15}},"biography":{"description":"<p>The dwarves are a sturdy but diminutive people, quite similar to humans but slower and more thoughtful in nature. They can be stubborn, greedy and stoic, but make firm friends if treated with respect. Their great Kingdoms lie underground, where they war constantly with the goblins and hobgoblins, who covet their treasures as well as their fine Dwarven halls.</p>"},"type":"Civilised","weaponSkill":6,"adventuringSkills":5,"gear":{"weapons":[],"armour":[],"equipment":[]}},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"prototypeToken":{"name":"Dwarf","displayName":0,"actorLink":false,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"light":{"alpha":0.5,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false,"type":null},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false,"texture":{"src":"systems/warlock/assets/icons/monsters/dwarf-face.svg","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"color":null,"attenuation":0.1,"saturation":0,"contrast":0,"visionMode":"basic"},"detectionModes":[]},"_stats":{"systemId":"warlock","systemVersion":"2.0.0","coreVersion":"10.284","createdTime":1662145221679,"modifiedTime":1662411890781,"lastModifiedBy":"6R9Y3cM97XtOXeBn"}}
{"_id":"vshLpxVDUfsApzUN","name":"Lich","type":"Monster","img":"systems/warlock/assets/icons/monsters/crowned-skull.svg","items":[{"_id":"2ktGhFpCrExRis0H","name":"Intelligent","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":-100000,"flags":{"core":{"sourceId":"Item.viEhV1k2WBxXnAHV"}},"system":{"description":"<p>This being is intelligent, can speak (but perhaps not in a tongue the characters know) and use tools and weapons. It is also able to create strategies and plans.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"WJsntmbQ722DrW2r","name":"Spell caster","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":0,"flags":{"core":{"sourceId":"Item.FOVCFt6tZfXWVBEK"}},"system":{"description":"<p>The being is able to cast spells. The games master should feel free to assign the creature spells that reflect its power. It uses stamina to cast spells and requires an incantation skill check.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.vshLpxVDUfsApzUN"}},"system":{"resources":{"actionsPerRound":{"value":3,"max":3},"stamina":{"value":45,"max":45}},"biography":{"description":"<p>Truly foul beings, lichs are created when magic is abused. These undead spell casters are not of this world. Resembling skeletons, they are obsessed with magic and their own power, and often raise armies of the undead to do their bidding. Truly mad, lichs are one of the most dangerous foes that the Kingdom faces - rumours persist that the Traitor was aided by lichs.</p>"},"type":"Otherworldly","weaponSkill":9,"adventuringSkills":6,"gear":{"weapons":[],"armour":[],"equipment":[]}},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"prototypeToken":{"name":"Lich","displayName":0,"actorLink":false,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"light":{"alpha":0.5,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false,"type":null},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false,"texture":{"src":"systems/warlock/assets/icons/monsters/crowned-skull.svg","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"color":null,"attenuation":0.1,"saturation":0,"contrast":0,"visionMode":"basic"},"detectionModes":[]},"_stats":{"systemId":"warlock","systemVersion":"2.0.0","coreVersion":"10.284","createdTime":1662145221682,"modifiedTime":1662411890782,"lastModifiedBy":"6R9Y3cM97XtOXeBn"}}
{"_id":"0ZWdgkhrG2uh3MtH","name":"Wight","type":"Monster","img":"systems/warlock/assets/icons/monsters/raise-skeleton.svg","items":[{"_id":"KixvwO7buDpF2wco","name":"Intelligent","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":700000,"flags":{"core":{"sourceId":"Item.viEhV1k2WBxXnAHV"}},"system":{"description":"<p>This being is intelligent, can speak (but perhaps not in a tongue the characters know) and use tools and weapons. It is also able to create strategies and plans.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.0ZWdgkhrG2uh3MtH"}},"system":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":33,"max":33}},"biography":{"description":"<p>Appearing much like emaciated near-skeletal humans, these undead have their own minds and desires. Wights often serve as the lieutenants of liches, where their armour-clad forms lead skeletal armies across the fields of war.</p>"},"type":"Otherworldly","weaponSkill":9,"adventuringSkills":6,"gear":{"weapons":[],"armour":[],"equipment":[]}},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"prototypeToken":{"name":"Wight","displayName":0,"actorLink":false,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"light":{"alpha":0.5,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false,"type":null},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false,"texture":{"src":"systems/warlock/assets/icons/monsters/shambling-zombie.svg","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"