eavy":"Heavy"}},"reductionRoll":"2d6"},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"QaA3Gi2Un4EPbZpS","name":"Intelligent","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":550000,"flags":{"core":{"sourceId":"Item.viEhV1k2WBxXnAHV"}},"system":{"description":"<p>This being is intelligent, can speak (but perhaps not in a tongue the characters know) and use tools and weapons. It is also able to create strategies and plans.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"CvNN02MQpAIWggi1","name":"Spell caster","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":600000,"flags":{"core":{"sourceId":"Item.FOVCFt6tZfXWVBEK"}},"system":{"description":"<p>The being is able to cast spells. The games master should feel free to assign the creature spells that reflect its power. It uses stamina to cast spells and requires an incantation skill check.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"mQB6q2P3Cz6si7aD","name":"Flame","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":400000,"flags":{"core":{"sourceId":"Item.v0qPMiXi02rlF9YG"}},"system":{"description":"<p>The being has a flame attack that they can use once a round that ignores armour.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"WoVNwpe0AOiAlGcF","name":"Flying","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":500000,"flags":{"core":{"sourceId":"Item.2RsIqNmhzsx9vw6I"}},"system":{"description":"<p>Using wings or similar, this creature can fly. Treat this as normal movement, but ignoring barriers that can be flown over at the game master's discretion. This creature cannot be engaged in melee combat whilst flying unless it chooses to attack, in which case it can be targeted.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.MnNmRePopM9xramP"}},"system":{"resources":{"actionsPerRound":{"value":5,"max":5},"stamina":{"value":62,"max":62}},"biography":{"description":"<p>The most fearsome creatures known, dragons marry unparalleled strength and power with intelligence and cunning, and are known weavers of spells. They can invariably talk, and like to converse with their visitors. They are large and sinuous, with a snakelike lizard body, great wings and huge jaws. Many breath flame, and can destroy whole towns when angered.</p>"},"type":"Monster","weaponSkill":11,"adventuringSkills":8,"gear":{"weapons":[],"armour":[],"equipment":[]}},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"prototypeToken":{"name":"Dragon","displayName":0,"actorLink":false,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"light":{"alpha":0.5,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false,"type":null},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false,"texture":{"src":"systems/warlock/assets/icons/monsters/spiked-dragon-head.svg","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"color":null,"attenuation":0.1,"saturation":0,"contrast":0,"visionMode":"basic"},"detectionModes":[]},"_stats":{"systemId":"warlock","systemVersion":"2.0.0","coreVersion":"10.284","createdTime":1662145221657,"modifiedTime":1662411890771,"lastModifiedBy":"6R9Y3cM97XtOXeBn"}}
{"_id":"RoI81YH8fC0JgPxK","name":"Skeleton","type":"Monster","img":"systems/warlock/assets/icons/monsters/raise-skeleton.svg","items":[{"_id":"uu6sMFm5OIxj4W9p","name":"Puppet","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":900000,"flags":{"core":{"sourceId":"Item.1pFoPKZbqGue8hfO"}},"system":{"description":"<p>The creature has no will of its own and must be directed by another mind. In consequence, it never surrenders or flees and will fight until destroyed.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"WCpAnZiH3O51rsFq","name":"Brittle","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":100000,"flags":{"core":{"sourceId":"Item.NJDwGhfTMjpd2eTv"}},"system":{"description":"<p>This creature is susceptible to impact damage. If maces, clubs or hammers attack them successfully, the damage is rolled twice and the higher value is applied.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.RoI81YH8fC0JgPxK"}},"system":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":8,"max":8}},"biography":{"description":"<p>A mindless undead, typically under the command of a lich, skeletons are brittle and suffer great damage from blunt weapons, but will fight until destroyed if commanded to. Some wizards practice the creation of skeleton servants, but such activities are frowned upon, and necromancers are often driven from civilised lands and hunted.</p>"},"type":"Otherworldly","weaponSkill":4,"adventuringSkills":3,"gear":{"weapons":[],"armour":[],"equipment":[]}},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"prototypeToken":{"name":"Skeleton","displayName":0,"actorLink":false,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"light":{"alpha":0.5,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false,"type":null},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false,"texture":{"src":"systems/warlock/assets/icons/monsters/raise-skeleton.svg","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"color":null,"attenuation":0.1,"saturation":0,"contrast":0,"visionMode":"basic"},"detectionModes":[]},"_stats":{"systemId":"warlock","systemVersion":"2.0.0","coreVersion":"10.284","createdTime":1662145221662,"modifiedTime":1662411890774,"lastModifiedBy":"6R9Y3cM97XtOXeBn"}}
{"_id":"Sc2oS6hejTd1QG8T","name":"Hobgoblin","type":"Monster","img":"systems/warlock/assets/icons/monsters/orc-head.svg","items":[{"_id":"xPvx0gCpUKYX8KeL","name":"Intelligent","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":700000,"flags":{"core":{"sourceId":"Item.viEhV1k2WBxXnAHV"}},"system":{"description":"<p>This being is intelligent, can speak (but perhaps not in a tongue the characters know) and use tools and weapons. It is also able to create strategies and plans.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.Sc2oS6hejTd1QG8T"}},"system":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":18,"max":18}},"biography":{"description":"<p>In truth goblins come in all shapes and sizes and the larger, more aggressive variety that rule over their smaller brethren are called hobgoblins. They are less hunched than their smaller kin, and can stand almost human height. Wicked and unpredictable, they are a violent and savage race, but not unintelligent - they make their own weapons and armour, and form bands under charismatic leaders that can threaten the stability of the realm.</p>"},"type":"Uncivilised","weaponSkill":7,"adventuringSkills":4,"gear":{"weapons":[],"armour":[],"equipment":[]}},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"prototypeToken":{"name":"Hobgoblin","displayName":0,"actorLink":false,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"light":{"alpha":0.5,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false,"type":null},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false,"texture":{"src":"systems/warlock/assets/icons/monsters/orc-head.svg","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"color":null,"attenuation":0.1,"saturation":0,"contrast":0,"visionMode":"basic"},"detectionModes":[]},"_stats":{"systemId":"warlock","systemVersion":"2.0.0","coreVersion":"10.284","createdTime":1662145221665,"modifiedTime":1662411890775,"lastModifiedBy":"6R9Y3cM97XtOXeBn"}}
{"_id":"WAm68bgrBG1uUeOw","name":"Halfling","type":"Monster","img":"systems/warlock/assets/icons/monsters/monk-face.svg","items":[{"_id":"H5fx6Mapo8XcIIbp","name":"Intelligent","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":700000,"flags":{"core":{"sourceId":"Item.viEhV1k2WBxXnAHV"}},"system":{"description":"<p>This being is intelligent, can speak (but perhaps not in a tongue the characters know) and use tools and weapons. It is also able to create strategies and plans.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.WAm68bgrBG1uUeOw"}},"system":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":8,"max":8}},"biography":{"description":"<p>A small folk, halflings are fairly commonly seen, and are quite integrated into human society. They are friendly and warm, quick to anger but quick to joy, and nicknamed the children due to their capricious but ultimately kind nature.</p>"},"type":"Civilised","weaponSkill":5,"adventuringSkills":5,"gear":{"weapons":[],"armour":[],"equipment":[]}},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"prototypeToken":{"name":"Halfling","displayName":0,"actorLink":false,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"light":{"alpha":0.5,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false,"type":null},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false,"texture":{"src":"systems/warlock/assets/icons/monsters/monk-face.svg","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"color":null,"attenuation":0.1,"saturation":0,"contrast":0,"visionMode":"basic"},"detectionModes":[]},"_stats":{"systemId":"warlock","systemVersion":"2.0.0","coreVersion":"10.284","createdTime":1662145221668,"modifiedTime":1662411890776,"lastModifiedBy":"6R9Y3cM97XtOXeBn"}}
{"_id":"c8HH0N1RZIEeNHXo","name":"Elf","type":"Monster","img":"systems/warlock/assets/icons/monsters/woman-elf-face.svg","items":[{"_id":"z68QJapoiEiNhFtt","name":"Intelligent","type":"Ability","img":"icons/svg/item-bag.svg","effects":[],"folder":"jZ1bx1OgshF0koNu","sort":700000,"flags":{"core":{"sourceId":"Item.viEhV1k2WBxXnAHV"}},"system":{"description":"<p>This being is intelligent, can speak (but perhaps not in a tongue the characters know) and use tools and weapons. It is also able to create strategies and plans.</p>"},"ownership":{"default":0,"XMfgoFiiE1BZBDoZ":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.warlock.bestiary-warlock.c8HH0N1RZIEeNHXo"}},"system":{"resources":{"actionsPerRound":{"value":1,"max":1},"stamina":{"value":15,"max":15}},"biography":{"description":"<p>Elves are typically seen in the forests of the Kingdom, but they do come into the towns and cities, usually to barter goods with other folk. Tall and slight with dark hair and pointed ears, there is no mistaking an elf. They make good companions, but they often seem aloof, are prone to arrogance and can show contempt for 'lesser' races, which makes them outsiders in the polite society.</p>"},"type":"Civilised","weaponSkill":6,"adventuringSkills":5,"gear":{"weapons":[],"armour":[],"equipment":[]}},"ownership":{"default":0,"HcHB4gb18gtp2Q2n":3},"prototypeToken":{"name":"Elf","displayName":0,"actorLink":false,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"light":{"alpha":0.5,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false,"type":null},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"disposition":-1,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false,"texture":{"src":"systems/warlock/assets/icons/monsters/woman-elf-face.svg","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"color":null,"attenuation":0.1,"saturation":0,"contrast":0,"visionMode":"basic"},"detectionModes":[]},"_stats":{"systemId":"warlock","systemVersion":"2.0.0","coreVersion":"10.284","createdTime":1662145221671,"modifiedTime":1662411890777,"lastModifiedBy":"6R9Y3cM97XtOXeBn"}}
