rcing","Slashing":"Slashing","Energy":"Energy","Ship":"Ship"}}}},"skill":{"value":"Ship gunner","choices":{"warlock":{"—":"—","Blunt":"Blunt","Bow":"Bow","Brawling":"Brawling","Crossbow":"Crossbow","Large blade":"Large blade","Pole arm":"Pole arm","Small blade":"Small blade","Thrown":"Thrown"},"warpstar":{"—":"—","Blades":"Blades","Blunt":"Blunt","Brawling":"Brawling","Ship gunner":"Ship gunner","Small arms":"Small arms","Thrown":"Thrown"}}},"activeSystem":"warlock"},"ownership":{"default":0,"ZtfDqSvKTGtngaYG":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"hb1EaTQBXo1fP2va","name":"Light armour","type":"Armour","img":"systems/warlock/assets/icons/items/armour/metal-plate.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":"","isEquipped":true,"type":{"value":"Light","choices":{"":"","Light":"Light","Modest":"Modest","Heavy":"Heavy"}},"reductionRoll":"1d3"},"ownership":{"default":0,"ZtfDqSvKTGtngaYG":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":0,"flags":{},"system":{"biography":{"description":"<p>Fast, lightly armed and spacious, the d'Aubigny-class Envoy, as its name suggests, is a popular ship amongst nobles, diplomats and professionals across the Chorus of a million worlds. Their design is sleek and slender, usually adorned with various cosmetic modifications as befits the owner. These ships have become somewhat popular amongst young bored nobles embarking on their 'grand tour' across the Chorus, making them a target for pirates seeking to ransom noble scions back to the Feudal Families. The d'Aubigny is not a ship of war, but does have enough firepower to dissuade minor threats. These ships are ideal for those who prefer to carry people over cargo, and want no problem docking in the better spaceports. They are comfortable, often well maintained, and usually come with an on-board robot valet to cater to most needs.</p>","notes":""},"capabilities":{"manoeuvrability":-1,"shipGun":-2,"antiPersonnelGun":-1,"scanners":2,"astronav":1},"structure":{"value":12,"max":12},"gear":{"weapons":[],"armour":[],"equipment":[]}},"ownership":{"default":0,"ZtfDqSvKTGtngaYG":3},"prototypeToken":{"name":"d'Aubigny Envoy Cruiser","displayName":0,"actorLink":true,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"light":{"alpha":0.5,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false,"type":null},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"disposition":0,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false,"texture":{"src":"systems/warlock/assets/icons/vehicles/spaceship.svg","scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0,"tint":null},"sight":{"angle":360,"enabled":false,"range":0,"brightness":1,"color":null,"attenuation":0.1,"saturation":0,"contrast":0,"visionMode":"basic"},"detectionModes":[]},"_stats":{"systemId":"warlock","systemVersion":"2.0.0","coreVersion":"10.284","createdTime":1662145223419,"modifiedTime":1662411891278,"lastModifiedBy":"6R9Y3cM97XtOXeBn"}}
