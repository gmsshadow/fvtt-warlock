{"_id":"Q9HTdkFCVMk5IuCj","name":"Comblis Relief Craft","type":"Vehicle","img":"systems/warlock/assets/icons/vehicles/spaceship.svg","items":[{"_id":"zd5n0oDdfy3aLR2X","name":"Light armour","type":"Armour","img":"systems/warlock/assets/icons/items/armour/metal-plate.svg","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":"","isEquipped":true,"type":{"value":"Light","choices":{"":"","Light":"Light","Modest":"Modest","Heavy":"Heavy"}},"reductionRoll":"1d3"},"ownership":{"default":0,"ZtfDqSvKTGtngaYG":3},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":0,"flags":{},"system":{"biography":{"description":"<p>The peaceful and cooperative Comblis are a welcome sight across the many beleaguered worlds of the Chorus. Rushing in medical aid, supplies and medicines, the Comblis are a neutral party (officially part of the Warp Consortium) in most affairs, and are recognised as such. Only the most murderous and barbarous species refuse to recognise the squatand defenceless box that is a Comblis relief ship.</p>","notes":""},"capabilities":{"manoeuvrability":1,"shipGun":0,"antiPersonnelGun":0,"scanners":4,"astronav":2},"structure":{"value":20,"max":20},"gear":{"weapons":[],"armour":[],"equipment":[]}},"ownership":{"default":0,"ZtfDqSvKTGtngaYG":3},"prototypeToken":{"name":"Comblis Relief Craft","displayName":0,"actorLink":true,"width":1,"height":1,"lockRotation":false,"rotation":0,"alpha":1,"light":{"alpha":0.5,"angle":360,"bright":0,"coloration":1,"dim":0,"luminosity":0.5,"saturation":0,"contrast":0,"shadows":0,"animation":{"speed":5,"intensity":5,"reverse":false,"type":null},"darkness":{"min":0,"max":1},"attenuation":0.5,"color":null},"disposition":0,"displayBars":0,"bar1":{"attribute":null},"bar2":{"attribute":null},"flags":{},"randomImg":false,"texture":{"src":"systems/warlock/assets/icons/vehicles/spaceship.svg","scaleX":1,"scaleY":1,"offsetX"