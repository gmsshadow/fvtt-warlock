<form
    class="{{cssClass}} document"
    autocomplete="off">
    <header class="header">
        <img
            class="header__image header__image--small"
            src="{{item.img}}"
            data-edit="img">

        <div class="header__body">
            <div class="header__row">
                <input
                    class="header__name header__name--small field field--no-decoration field--center"
                    type="text"
                    name="name"
                    value="{{item.name}}"
                    data-dtype="String">
            </div>

            <div class="header__row">
                <div class="resource">
                    <label class="resource__name">
                        {{localize "WARLOCK.Items.Weapon.Skill"}}
                    </label>

                    <div class="resource__body">
                        <select
                            class="field field--no-decoration"
                            name="system.skill.value">
                            {{selectOptions
                                data.system.skill.choices
                                selected=data.system.skill.value}}
                        </select>
                    </div>
                </div>

                <div class="resource">
                    <label class="resource__name">
                        {{localize "WARLOCK.Items.Weapon.Type"}}
                    </label>

                    <div class="resource__body">
                        <select
                            class="field field--no-decoration"
                            name="system.type.value">
                            {{selectOptions
                                data.system.type.choices
                                selected=data.system.type.value}}
                        </select>
                    </div>
                </div>

                <div class="resource">
                    <label class="resource__name">
                        {{localize "WARLOCK.Items.Weapon.DamageRoll"}}
                    </label>

                    <div class="resource__body">
                        <input
                            class="field field--center field--no-decoration"
                            type="text"
                            name="system.damage.roll"
                            value="{{data.system.damage.roll}}"
                            data-dtype="String">
                    </div>
                </div>

                <div class="resource">
                    <label class="resource__name">
                        {{localize "WARLOCK.Items.Weapon.DamageType"}}
                    </label>

                    <div class="resource__body">
                        <select
                            class="field field--no-decoration"
                            name="system.damage.type.value">
                            {{selectOptions
                                data.system.damage.type.choices
                                selected=data.system.damage.type.value}}
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section class="body">
        <div class="flex flex--column flex--no-gap">
            <h1>
                {{localize "WARLOCK.Items.Weapon.Description"}}
            </h1>

            {{editor
                data.system.description
                target="system.description"
                button=true
                owner=owner
                editable=editable}}
        </div>
    </section>
</form>
