<div class="warlock dice-roll">
    {{#if flavor}}
    <div class="dice-roll__flavor">
        {{flavor}}
    </div>
    {{/if}}
    <div class="dice-roll__result ">
        <div class="dice-roll__formula">
            {{formula}}
        </div>
        {{{tooltip}}}
        <h4 class="dice-roll__total">
            {{total}}
        </h4>
        {{#unless isOpposed}}
        {{#if (gte total 20)}}
        <div class="dice-roll__flag dice-roll__flag--success">
            {{localize "WARLOCK.Success!"}}
        </div>
        {{else}}
        <div class="dice-roll__flag dice-roll__flag--failure">
            {{localize "WARLOCK.Failure!"}}
        </div>
        {{/if}}
        {{/unless}}
    </div>
</div>