<div class="weapons table">
    <div class="weapons__header table__header">
        <span class="weapons__header-field table__header-field">
            {{localize "WARLOCK.Weapon"}}
        </span>
        <span class="weapons__header-field table__header-field">
            {{localize "WARLOCK.Skill"}}
        </span>
        <span class="weapons__header-field table__header-field">
            {{localize "WARLOCK.Type"}}
        </span>
        <span class="weapons__header-field table__header-field">
            {{localize "WARLOCK.Damage"}}
        </span>
        <span class="weapons__header-field table__header-field">
            <a
                class="create-item"
                data-item-type="Weapon">
                <i class="fas fa-plus"></i> Add
            </a>
        </span>
    </div>
    <div class="weapons__body table__body">
        {{#each data.data.gear.weapons}}
        <div
            class="weapons__entry table__entry"
            data-skill="{{data.data.skill.value}}"
            data-item-id="{{id}}">
            <span
                class="weapons__entry-field table__entry-field"
                title="{{localize "WARLOCK.Weapon"}}">
                <img
                    class="table__entry-image"
                    src="{{img}}">
                <a class="toggle-description">
                    {{name}}
                </a>
            </span>
            <span
                class="weapons__entry-field table__entry-field"
                title="{{localize "WARLOCK.Skill"}}">
                {{#if (or
                        (eq data.data.skill.value "—")
                        (or
                            (eq data.document.parent.type "Monster")
                            (eq data.document.parent.type "Vehicle")))}}
                —
                {{else}}
                <a
                    class="test-skill"
                    title="{{localize "WARLOCK.TestSkill"}}">
                    {{data.data.skill.value}}
                </a>
                {{/if}}
            </span>
            <span
                class="weapons__entry-field table__entry-field"
                title="{{localize "WARLOCK.Type"}}">
                {{data.data.type.value}}
            </span>
            <span
                class="weapons__entry-field table__entry-field"
                title="{{localize "WARLOCK.Damage"}}">
                <a class="roll-weapon">
                    {{data.data.damage.roll}} {{data.data.damage.type.value}}
                </a>
            </span>
            <span class="weapons__entry-field table__entry-field">
                <a
                    class="equip-item"
                    title="{{localize "WARLOCK.IsEquipped"}}">
                    {{#if data.data.isEquipped}}
                    <i class="fas fa-tshirt equip-item__equipped"></i>
                    {{else}}
                    <i class="fas fa-tshirt equip-item__not-equipped"></i>
                    {{/if}}
                </a>
                <a
                    class="chat-item"
                    title="{{localize "WARLOCK.ChatWeapon"}}">
                    <i class="fas fa-comment"></i>
                </a>
                <a
                    class="edit-item"
                    title="{{localize "WARLOCK.EditWeapon"}}">
                    <i class="fas fa-edit"></i>
                </a>
                <a
                    class="delete-item"
                    title="{{localize "WARLOCK.DeleteWeapon"}}">
                    <i class="fas fa-trash"></i>
                </a>
            </span>
        </div>
        <div class="table__entry-field--collapsible">
            {{{enrichHTML data.data.description}}}
        </div>
        {{/each}}
    </div>
</div>